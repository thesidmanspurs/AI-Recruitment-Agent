// Prisma schema — PostgreSQL
// Local dev:  postgresql://postgres:password@localhost:5432/recruitment_agent
// GCP Cloud SQL (Unix socket): postgresql://user:password@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id                 String       @id @default(uuid())
  email              String       @unique
  name               String
  // Nullable: accounts created via Google OAuth have no local password.
  // Password login is rejected for such accounts (see authService.login).
  passwordHash       String?
  role               UserRole     @default(USER)
  isBlocked          Boolean      @default(false)
  blockedAt          DateTime?
  blockedReason      String?
  dailyLimitOverride Int?         // null = inherit the global daily_free_limit setting
  lastLoginAt        DateTime?

  // ── Google OAuth ──────────────────────────────────────────────────────
  // Google account subject id ("sub"), set when a user signs in with Google.
  // Unique so one Google account maps to exactly one user. A pre-existing
  // password account is linked by matching the verified Google email.
  googleId           String?      @unique
  avatarUrl          String?      // Google profile picture (optional)

  // ── Billing / credits ─────────────────────────────────────────────────
  // Spendable credit balance. Consumed (1 per reveal) when the user unlocks
  // a candidate's email/phone via Apollo. Topped up by Stripe purchases.
  creditBalance        Int       @default(0)
  // Stripe customer id (created lazily on first checkout). Reused so a user
  // has one customer record across purchases + the subscription portal.
  stripeCustomerId     String?   @unique
  // Start Tier subscription tracking. Null when the user has no active sub.
  stripeSubscriptionId String?
  subscriptionStatus   String?   // Stripe status: active | past_due | canceled | …
  subscriptionPlan     String?   // package id, e.g. "start-tier"
  subscriptionCurrentPeriodEnd DateTime?
  // Recruiter's email signature. Appended to every outreach body so Gemini
  // never has to invent a closing block. Editable from the outreach modal.
  outreachSignature  String?      @db.Text

  // ── Per-user outreach email config ────────────────────────────────────
  // Each recruiter sends from their OWN email. No shared mailbox. Outreach
  // is blocked until emailVerifiedAt is set via a successful test send.
  emailProvider      EmailProvider?            // GMAIL | RESEND | null (unset)
  emailFromAddress   String?                   // e.g. "jane@acme.com"
  emailFromName      String?                   // e.g. "Jane Smith"
  // Credentials are AES-256-GCM encrypted at rest (see utils/crypto.ts).
  // Never returned to the client — the API exposes only a "configured" flag.
  gmailAppPasswordEnc String?     @db.Text     // encrypted Gmail app password
  resendApiKeyEnc     String?     @db.Text     // encrypted Resend API key
  emailVerifiedAt    DateTime?                 // last successful test-send

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  campaigns          Campaign[]
  usage              UsageDaily[]
  emailRequests      EmailRequest[]
  creditTransactions CreditTransaction[]

  @@index([email])
}

// ─── Billing ──────────────────────────────────────────────────────────────────

enum CreditTransactionType {
  SUBSCRIPTION_GRANT // monthly Start Tier invoice paid → +2000
  TOPUP_PURCHASE     // one-time Top-Up Pack → +1000
  SPEND              // Apollo reveal → negative credits
  ADMIN_GRANT        // manual adjustment by an admin
  REFUND             // credits returned (e.g. failed reveal after debit)
}

enum CreditTransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

// Unified ledger: every credit movement (purchase, grant, spend) is one row.
// Doubles as the user's payment history and the spend audit trail. `credits`
// is signed: positive for grants/purchases, negative for spends.
model CreditTransaction {
  id       String                  @id @default(uuid())
  userId   String
  user     User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type     CreditTransactionType
  status   CreditTransactionStatus @default(COMPLETED)
  credits  Int // signed delta applied to the balance
  // Money fields populated for purchases/grants (0 for spends).
  amountCents Int    @default(0)
  currency    String @default("usd")
  // Human-readable reason / context (e.g. "Apollo reveal: 3 candidate(s)").
  reason      String?
  // Balance immediately after this transaction (snapshot for the history UI).
  balanceAfter Int?
  packageId    String? // credit package id when applicable

  // Stripe correlation ids. Each is unique where present so a replayed webhook
  // (or the verify-session fallback) can never double-credit the same payment.
  stripeSessionId       String? @unique
  stripePaymentIntentId String?
  stripeInvoiceId       String? @unique

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

// Idempotency guard for Stripe webhooks: insert the event id the first time we
// see it; a conflict means we already processed it and can skip.
model StripeWebhookEvent {
  eventId   String   @id // Stripe event.id (evt_…)
  type      String
  createdAt DateTime @default(now())
}

enum UserRole {
  USER
  ADMIN
}

enum EmailProvider {
  GMAIL
  RESEND
}

enum EmailRequestStatus {
  PENDING
  CONFIGURED
  REJECTED
}

// A user's request for the admin to set up Resend sending on their behalf.
// Users can't self-configure Resend (needs a company API key) — they submit
// this form and an admin configures their email from the admin console.
model EmailRequest {
  id           String             @id @default(uuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactName  String
  whatsapp     String
  emailAccount String             // the address they want to send from
  domain       String             // their email domain (for Resend verification)
  status       EmailRequestStatus @default(PENDING)
  adminNote    String?            @db.Text
  createdAt    DateTime           @default(now())
  handledAt    DateTime?

  @@index([status])
  @@index([userId])
}

// Singleton key/value table for global settings. Admin-editable.
// Known keys: daily_free_limit  (integer, default 50)
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// Tracks how many AI-paid operations a user has consumed on a given UTC date.
// One row per (user, date). Incremented on every successful Gemini call.
model UsageDaily {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   // YYYY-MM-DD (UTC) — kept as string so unique index is trivial
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// ─── Campaign (one per recruitment category/role) ────────────────────────────

model Campaign {
  id                 String         @id @default(uuid())
  userId             String
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String
  jobTitle           String
  rawJobText         String         @db.Text
  location           String?
  jobType            String?
  department         String?
  status             CampaignStatus @default(DRAFT)
  code               String?
  analyzedAt         DateTime?
  alternateTitles    String[]
  extractedKeywords  String[]
  requirements       String[]
  preferredPlatforms String[]
  // Campaign-level outreach template. When set, the outreach editor
  // pre-fills from this instead of calling Gemini per-candidate. Stored as
  // "Subject\n\nBody" with {{placeholders}} the backend substitutes at draft
  // time. Empty/null = fall back to Gemini per-candidate generation.
  outreachTemplate   String?        @db.Text
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  candidates         Candidate[]
  activityLogs       ActivityLog[]

  @@index([userId])
  @@index([userId, status])
}

enum CampaignStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

// ─── Candidate ───────────────────────────────────────────────────────────────

model Candidate {
  id               String          @id @default(uuid())
  campaignId       String
  campaign         Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name             String
  currentTitle     String
  company          String
  bio              String          @db.Text
  openToWork       Boolean         @default(false)
  platform         Platform
  matchScore       Float
  matchExplanation String          @db.Text
  skills           String[]
  strengths        String[]
  gaps             String[]

  // Contact — populated by Apollo (Phase 4)
  email         String?
  phone         String?
  location      String?
  linkedinUrl   String?
  emailEnriched Boolean @default(false)
  phoneEnriched Boolean @default(false)
  // Apollo internal person id — used to correlate async phone webhooks and
  // on-demand enrichment. NOT globally unique: the same Apollo person can be
  // sourced into multiple campaigns (or re-sourced), so we index it for
  // lookup but allow duplicates.
  apolloId      String?
  // When Apollo last refreshed this person's record (their updated_at).
  // Used to render "Data verified MMM YYYY" and warn on stale rows.
  apolloUpdatedAt    DateTime?
  // Start date of the candidate's current role per Apollo's
  // employment_history. Lets the UI show "Title since YYYY".
  currentRoleSince   DateTime?
  // True when Apollo's employment_history confirms the displayed title +
  // company are the candidate's CURRENT role (not the stale top-level one).
  isCurrentRole      Boolean   @default(false)

  // Outreach (Phase 5)
  outreachStatus    OutreachStatus   @default(SOURCED)
  outreachMessage   String?          @db.Text
  outreachChannel   OutreachChannel?
  outreachSentAt    DateTime?
  // Inbox-poller fills these when it finds a reply addressed to this
  // candidate's outreach. repliedAt is the timestamp Apollo/Gmail
  // reported; replyPreview is the first ~400 chars of the response body.
  repliedAt         DateTime?
  replyPreview      String?          @db.Text
  daysSinceOutreach Int              @default(0)
  alertTriggered    Boolean          @default(false)
  notes             String?          @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, name])
  @@index([campaignId])
  @@index([campaignId, matchScore])
  @@index([apolloId])
  @@index([campaignId, outreachStatus])
}

enum Platform {
  LinkedIn
  Upwork
  Reddit
}

enum OutreachStatus {
  SOURCED
  ENRICHED
  OUTREACH_SENT
  OPENED
  REPLIED
  NO_RESPONSE
}

enum OutreachChannel {
  EMAIL
  LINKEDIN_DM
  PLATFORM_MESSAGE
}

// ─── Activity Log ────────────────────────────────────────────────────────────

model ActivityLog {
  id            String          @id @default(uuid())
  campaignId    String
  campaign      Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  candidateId   String?
  candidateName String?
  message       String
  type          ActivityLogType
  timestamp     DateTime        @default(now())

  @@index([campaignId])
  @@index([campaignId, timestamp])
}

enum ActivityLogType {
  INFO
  ENRICH
  OUTREACH
  REPLY
  ALERT
  SYSTEM
}
