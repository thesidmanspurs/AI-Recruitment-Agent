# ─── Backend-only secrets — NEVER put any of these in frontend/.env ──────────
# Loaded by backend/config/env.ts and Prisma via prisma.config.ts.

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5433/recruitment_agent"
# GCP Cloud SQL (Unix socket — use in Cloud Run / App Engine):
# DATABASE_URL="postgresql://USER:PASSWORD@/DB_NAME?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME"

# Auth
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# AI Brain — Gemini (Phase 1, 2, 3, 5)
GEMINI_API_KEY=

# Contact Enrichment — Apollo (Phase 4)
APOLLO_API_KEY=

# GitHub sourcing — optional no-scope Personal Access Token (github.com →
# Settings → Developer settings → Tokens). Reads only public profiles; lifts
# the search rate limit. Works without it (lower volume).
GITHUB_TOKEN=

# Email Outreach — SMTP (Phase 5)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=recruiter@yourdomain.com

# Tracking
ALERT_THRESHOLD_HOURS=48

# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated list of allowed origins for /api.
# Empty = same-origin only. Wildcard "*" is rejected when credentials are used.
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Billing / Stripe — credits are spent only on Apollo email/phone reveals.
# Use test-mode (sandbox) keys for development:
#   - STRIPE_SECRET_KEY:      Stripe Dashboard → Developers → API keys (sk_test_…)
#   - STRIPE_WEBHOOK_SECRET:  from `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
#   - STRIPE_PUBLISHABLE_KEY: optional (pk_test_…), only if mounting Stripe.js
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
# Public origin used for Checkout success/cancel redirects (falls back to APP_BASE_URL).
APP_URL=http://localhost:3000

# Google OAuth (Sign in with Google) — from Google Cloud Console → Credentials.
# GOOGLE_REDIRECT_URI must EXACTLY match an Authorized redirect URI on the OAuth
# client. Defaults to APP_URL + /api/callback. For local dev add
# http://localhost:3000/api/callback to the client's redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
